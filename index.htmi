 <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HEPM-TECH Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 font-sans">
    <div id="login-screen" class="min-h-screen flex items-center justify-center bg-blue-600 p-4">
        <div class="bg-white p-8 rounded-lg shadow-xl w-full max-w-md">
            <h1 class="text-2xl font-bold text-center text-blue-600 mb-6">HEPM-TECH Login</h1>
            <input type="password" id="password" placeholder="Enter Password" class="w-full p-3 border border-gray-300 rounded mb-4 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <button onclick="checkPassword()" class="w-full bg-blue-600 text-white font-bold py-3 rounded hover:bg-blue-700 transition">Enter Dashboard</button>
            <p id="error-msg" class="text-red-500 text-sm mt-3 hidden text-center">Incorrect Password!</p>
        </div>
    </div>

    <div id="dashboard" class="hidden min-h-screen p-4 md:p-8">
        <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-lg p-6">
            <h1 class="text-3xl font-bold text-blue-600 mb-6 border-b pb-4 text-center">HEPM-TECH Admin</h1>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                <input type="text" id="name" placeholder="Full Name" class="p-3 border rounded shadow-sm">
                <input type="text" id="phone" placeholder="Phone Number" class="p-3 border rounded shadow-sm">
                <input type="number" id="amount" placeholder="Amount (Debt)" class="p-3 border rounded shadow-sm">
            </div>
            <button onclick="addDebtor()" class="w-full bg-green-500 text-white font-bold py-3 rounded hover:bg-green-600 transition mb-8 shadow-md">Add Debtor</button>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse border border-gray-200">
                    <thead class="bg-blue-100">
                        <tr>
                            <th class="p-4 border">Name</th>
                            <th class="p-4 border">Phone</th>
                            <th class="p-4 border">Amount</th>
                            <th class="p-4 border">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="debtor-list"></tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        const AUTH_PASS = "Girmay2026";
        function checkPassword() {
            const pass = document.getElementById("password").value;
            if (pass === AUTH_PASS) {
                document.getElementById("login-screen").classList.add("hidden");
                document.getElementById("dashboard").classList.remove("hidden");
                displayDebtors();
            } else {
                document.getElementById("error-msg").classList.remove("hidden");
            }
        }

        function addDebtor() {
            const name = document.getElementById("name").value;
            const phone = document.getElementById("phone").value;
            const amount = document.getElementById("amount").value;
            if (name && phone && amount) {
                const debtors = JSON.parse(localStorage.getItem("debtors") || "[]");
                debtors.push({ name, phone, amount, id: Date.now() });
                localStorage.setItem("debtors", JSON.stringify(debtors));
                displayDebtors();
                document.getElementById("name").value = "";
                document.getElementById("phone").value = "";
                document.getElementById("amount").value = "";
            }
        }

        function displayDebtors() {
            const list = document.getElementById("debtor-list");
            const debtors = JSON.parse(localStorage.getItem("debtors") || "[]");
            list.innerHTML = debtors.map(d => `
                <tr class="hover:bg-gray-50 border-b">
                    <td class="p-4 font-medium">${d.name}</td>
                    <td class="p-4"><a href="tel:${d.phone}" class="text-blue-600 underline">${d.phone}</a></td>
                    <td class="p-4 font-bold text-red-600">${d.amount}</td>
                    <td class="p-4"><button onclick="deleteDebtor(${d.id})" class="bg-red-500 text-white px-3 py-1 rounded text-sm hover:bg-red-600">Delete</button></td>
                </tr>
            `).join("");
        }

        function deleteDebtor(id) {
            let debtors = JSON.parse(localStorage.getItem("debtors") || "[]");
            debtors = debtors.filter(d => d.id !== id);
            localStorage.setItem("debtors", JSON.stringify(debtors));
            displayDebtors();
        }
    </script>
</body>
</html>